# Copia aquest fitxer a `.env.local` i omple-hi els valors reals.
# `.env.local` està al .gitignore — no es puja a git.

# Supabase — públiques per disseny (l'anon key va al client)
# A Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Google AI Studio (Gemini) — server-side, no s'exposa al client
# Crea una key gratis a https://aistudio.google.com/app/apikey (sense targeta)
GOOGLE_AI_API_KEY=AIza...
